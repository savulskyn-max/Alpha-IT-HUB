# ============================================
# Alpha IT Hub - Backend Environment Variables
# Copy this file to .env and fill in values
# ============================================

# App
APP_ENV=development
DEBUG=true
FRONTEND_URL=http://localhost:3000
# Regex optional for preview domains (recommended for Vercel previews)
CORS_ORIGIN_REGEX=^https://.*\.vercel\.app$
# Accepts CSV (https://a.com,https://b.com) or JSON list (["https://a.com","https://b.com"])
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8081,exp://localhost:8081

# Supabase (Platform DB)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here
SUPABASE_JWT_SECRET=your-jwt-secret-here

# Platform PostgreSQL (direct connection via asyncpg)
# Format: postgresql+asyncpg://user:password@host:5432/database
DATABASE_URL=postgresql+asyncpg://postgres:password@db.your-project.supabase.co:5432/postgres

# Azure Key Vault (optional - leave empty to use Supabase Vault)
AZURE_KEY_VAULT_URL=
AZURE_CLIENT_ID=
AZURE_CLIENT_SECRET=
AZURE_TENANT_ID_AAD=

# Security
SECRET_KEY=change-me-in-production
